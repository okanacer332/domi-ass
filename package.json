{
  "name": "domizan",
  "version": "0.1.2",
  "description": "Mali musavir ofisleri icin yapay zeka destekli masaustu operasyon platformu.",
  "main": "out/main/index.js",
  "author": "Domizan",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis --x64 --publish never",
    "dist:mac:intel": "npm run build && electron-builder --mac dmg zip --x64 --publish never",
    "dist:mac:apple": "npm run build && electron-builder --mac dmg zip --arm64 --publish never",
    "release:verify": "npm run build && npm --prefix backend run build",
    "release:patch": "npm version patch --no-git-tag-version && node tools/release-helper.cjs",
    "release:minor": "npm version minor --no-git-tag-version && node tools/release-helper.cjs",
    "release:major": "npm version major --no-git-tag-version && node tools/release-helper.cjs",
    "release:status": "node tools/release-helper.cjs",
    "release:tag": "node tools/release-helper.cjs create-tag",
    "release:publish-tag": "node tools/release-helper.cjs publish-tag"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^0.511.0",
    "papaparse": "^5.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "sql.js": "^1.13.0",
    "zod": "^3.25.67",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.domizan.desktop",
    "productName": "Domizan",
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "okanacer332",
        "repo": "domi-ass",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
